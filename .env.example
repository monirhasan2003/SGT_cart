# ==========================================================
# SGT Cart — Environment Variables (TEMPLATE)
# এই ফাইলটি কপি করে `.env` নাম দিন এবং আসল মান বসান।
# এই .env.example ফাইলটি Git-এ commit করা নিরাপদ (এতে কোনো গোপন তথ্য নেই)।
# ==========================================================

# ---- Flask ----
# Generate strong values for production with:
#     python -c "import secrets; print(secrets.token_hex(32))"
# `production` config refuses to boot with the dev placeholder.
SECRET_KEY=generate-a-long-random-hex-string
JWT_SECRET_KEY=generate-another-long-random-hex-string
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_CONFIG=development

# ---- PostgreSQL Database ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sgt_ecommerce
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/sgt_ecommerce

# ---- Redis (optional) ----
# Used as the rate-limit store, cache backend, and SocketIO message queue
# once you run multiple workers in production.
REDIS_URL=redis://localhost:6379/0
# Leave unset for single-process dev; set to a Redis URL to share SocketIO
# events across multiple gunicorn / Celery workers.
# SOCKETIO_MESSAGE_QUEUE=redis://localhost:6379/0

# ---- SSLCommerz Payment Gateway ----
# Leave blank to develop without online payments (Cash on Delivery works).
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=True

# ---- Email / SMTP (Gmail app password) ----
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_DEFAULT_SENDER=your_gmail@gmail.com

# ---- First super-admin account ----
ADMIN_EMAIL=admin@example.com

# ---- Firebase Cloud Messaging (push notifications, optional) ----
# Path to a Firebase service-account JSON file. Unset = push disabled
# (in-app + live SocketIO notifications still work; only device push is off).
# FCM_CREDENTIALS_FILE=C:/path/to/firebase-service-account.json
