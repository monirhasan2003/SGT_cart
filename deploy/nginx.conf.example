# SGT Cart — nginx reverse-proxy template.
#
# Replace `your-domain.com` and the paths under /opt/sgt/... with your own,
# obtain TLS certs (e.g. with certbot), and reload nginx.

upstream sgt_app {
    server 127.0.0.1:8000;
}

# HTTP -> HTTPS redirect (keep the ACME challenge path on plain HTTP).
server {
    listen 80;
    server_name your-domain.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name your-domain.com;

    ssl_certificate     /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;

    # Matches Flask's MAX_CONTENT_LENGTH (16 MB) for product/review uploads.
    client_max_body_size 16M;

    # Serve static + uploaded media directly from nginx (much faster than Flask).
    location /static/ {
        alias /opt/sgt/SGT_Ecommerce/app/static/;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }

    # Long-poll + WebSocket transport for Flask-SocketIO.
    location /socket.io/ {
        proxy_pass http://sgt_app;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 600s;
    }

    location / {
        proxy_pass http://sgt_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 90s;
    }
}
